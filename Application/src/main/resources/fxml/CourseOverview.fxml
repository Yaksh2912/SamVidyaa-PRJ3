<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.samvidya.controller.CourseOverviewController">
   <top>
      <VBox spacing="20.0" styleClass="header-section">
         <padding>
            <Insets bottom="20.0" left="30.0" right="30.0" top="30.0" />
         </padding>
         
         <!-- Course Header -->
         <HBox alignment="CENTER_LEFT" spacing="20.0">
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
               <Label fx:id="courseNameLabel" styleClass="course-title" text="Course Name">
                  <font>
                     <Font name="System Bold" size="28.0" />
                  </font>
               </Label>
               <HBox spacing="15.0">
                  <Label fx:id="courseCodeLabel" styleClass="course-code" text="CS101" />
                  <Separator orientation="VERTICAL" />
                  <Label fx:id="subjectLabel" styleClass="course-subject" text="Python" />
                  <Separator orientation="VERTICAL" />
                  <Label text="Instructor:" styleClass="label-secondary" />
                  <Label fx:id="instructorLabel" styleClass="instructor-name" text="Dr. John Smith" />
               </HBox>
            </VBox>
            <VBox alignment="TOP_RIGHT" spacing="5.0">
               <Label fx:id="statusLabel" styleClass="status-badge" text="Active" />
               <Label fx:id="progressLabel" styleClass="progress-text" text="0% Complete" />
            </VBox>
         </HBox>
         
         <!-- Progress Bar -->
         <VBox spacing="5.0">
            <Label text="Course Progress" styleClass="section-label" />
            <ProgressBar fx:id="courseProgressBar" maxWidth="Infinity" prefHeight="8.0" progress="0.0" styleClass="modern-progress" />
         </VBox>
         
         <!-- Course Stats -->
         <HBox spacing="30.0" alignment="CENTER_LEFT">
            <VBox alignment="CENTER" spacing="5.0" styleClass="stat-card">
               <padding>
                  <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
               </padding>
               <Label fx:id="totalModulesLabel" styleClass="stat-number" text="0" />
               <Label text="Modules" styleClass="stat-label" />
            </VBox>
            <VBox alignment="CENTER" spacing="5.0" styleClass="stat-card">
               <padding>
                  <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
               </padding>
               <Label fx:id="totalTasksLabel" styleClass="stat-number" text="0" />
               <Label text="Total Tasks" styleClass="stat-label" />
            </VBox>
            <VBox alignment="CENTER" spacing="5.0" styleClass="stat-card">
               <padding>
                  <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
               </padding>
               <Label fx:id="courseTestQuestionsLabel" styleClass="stat-number" text="5" />
               <Label text="Test Questions" styleClass="stat-label" />
            </VBox>
         </HBox>
      </VBox>
   </top>
   
   <center>
      <VBox spacing="20.0">
         <padding>
            <Insets bottom="20.0" left="30.0" right="30.0" top="10.0" />
         </padding>
         
         <!-- Course Description -->
         <VBox spacing="10.0">
            <Label text="Course Description" styleClass="section-title" />
            <TextArea fx:id="descriptionArea" prefRowCount="3" styleClass="description-area" 
                     text="Course description will appear here..." wrapText="true" />
         </VBox>
         
         <!-- Modules Section -->
         <VBox spacing="15.0" VBox.vgrow="ALWAYS">
            <Label text="Course Modules" styleClass="section-title" />
            
            <TableView fx:id="modulesTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="moduleOrderColumn" prefWidth="80.0" text="#" />
                  <TableColumn fx:id="moduleNameColumn" prefWidth="200.0" text="Module Name" />
                  <TableColumn fx:id="statusColumn" prefWidth="150.0" text="Status" />
                  <TableColumn fx:id="progressColumn" prefWidth="120.0" text="Progress" />
                  <TableColumn fx:id="accessColumn" prefWidth="100.0" text="Access" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </VBox>
      </VBox>
   </center>
   
   <bottom>
      <HBox alignment="CENTER_RIGHT" spacing="15.0" styleClass="button-bar">
         <padding>
            <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
         </padding>
         
         <Button fx:id="startModuleButton" onAction="#handleStartModule" 
                styleClass="primary-button" text="Start Module" />
         <Button fx:id="takeModuleTestButton" onAction="#handleTakeModuleTest" 
                styleClass="secondary-button" text="Take Module Test" />
         <Button fx:id="takeCourseTestButton" onAction="#handleTakeCourseTest" 
                styleClass="accent-button" text="Take Course Test" />
         <Button text="🛒 Shop" onAction="#handleShop"
                 style="-fx-background-color: #00897B; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 18;"/>
         <Region HBox.hgrow="ALWAYS" />
         <Button fx:id="closeButton" onAction="#handleClose" 
                styleClass="outline-button" text="Close" />
         
         <!-- Error Label -->
         <Label fx:id="errorLabel" styleClass="error-label" text="Error message" visible="false" />
      </HBox>
   </bottom>
</BorderPane>