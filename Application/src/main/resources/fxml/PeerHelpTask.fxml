<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.samvidya.controller.PeerHelpTaskController">
    <top>
        <VBox spacing="8" style="-fx-background-color: #1565C0; -fx-padding: 14 20;">
            <Label text="Peer Help Mode" style="-fx-font-size: 11px; -fx-text-fill: #90CAF9; -fx-font-weight: bold;"/>
            <HBox alignment="CENTER_LEFT" spacing="16">
                <Label fx:id="taskNameLabel" text="Task" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Difficulty:" style="-fx-text-fill: #ccc;"/>
                <Label fx:id="difficultyLabel" text="-" style="-fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Points:" style="-fx-text-fill: #ccc;"/>
                <Label fx:id="pointsLabel" text="-" style="-fx-text-fill: #FFD54F; -fx-font-weight: bold;"/>
                <Label text="Language:" style="-fx-text-fill: #ccc;"/>
                <Label fx:id="languageLabel" text="-" style="-fx-text-fill: white;"/>
            </HBox>
            <Label fx:id="helpingLabel" text="Helping: —"
                   style="-fx-font-size: 13px; -fx-text-fill: #A5D6A7;"/>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.35" orientation="VERTICAL">
            <!-- Problem + sample tests -->
            <SplitPane dividerPositions="0.65" orientation="HORIZONTAL">
                <VBox spacing="8" style="-fx-padding: 10;">
                    <Label text="Problem Statement:" style="-fx-font-weight: bold;"/>
                    <TextArea fx:id="problemStatementArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS"/>
                </VBox>
                <VBox spacing="8" style="-fx-padding: 10;">
                    <Label text="Sample Test Cases:" style="-fx-font-weight: bold;"/>
                    <TableView fx:id="sampleTestCasesTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="sampleInputColumn" text="Input" prefWidth="140"/>
                            <TableColumn fx:id="sampleOutputColumn" text="Expected Output" prefWidth="140"/>
                        </columns>
                    </TableView>
                </VBox>
            </SplitPane>

            <!-- Code editor + output -->
            <SplitPane dividerPositions="0.75" orientation="HORIZONTAL">
                <VBox spacing="8" style="-fx-padding: 10;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Your Solution:" style="-fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="statusLabel" text="Ready"/>
                        <ProgressBar fx:id="executionProgress" prefWidth="100" visible="false"/>
                        <Button fx:id="runCodeButton" text="▶ Run" onAction="#handleRunCode"
                                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 4;"/>
                        <Button fx:id="submitCodeButton" text="✓ Submit on Behalf" onAction="#handleSubmit"
                                style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4;"/>
                        <Button text="Cancel" onAction="#handleCancel"
                                style="-fx-background-color: #e53935; -fx-text-fill: white; -fx-background-radius: 4;"/>
                    </HBox>
                    <TextArea fx:id="codeArea" promptText="Write your solution here..." VBox.vgrow="ALWAYS"
                              style="-fx-font-family: monospace; -fx-font-size: 13px;"/>
                </VBox>
                <VBox spacing="8" style="-fx-padding: 10;">
                    <Label text="Output:" style="-fx-font-weight: bold;"/>
                    <TextArea fx:id="outputArea" editable="false" VBox.vgrow="ALWAYS"/>
                </VBox>
            </SplitPane>
        </SplitPane>
    </center>
</BorderPane>
