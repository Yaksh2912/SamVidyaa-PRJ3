<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.samvidya.controller.StudentModuleWorkspaceController">
   <top>
      <VBox spacing="10.0" styleClass="header-section">
         <padding>
            <Insets bottom="10.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <HBox alignment="CENTER_LEFT" spacing="20.0">
            <Button fx:id="toggleSidebarButton" onAction="#handleToggleSidebar" text="☰" styleClass="toggle-button" />
            <Label fx:id="moduleNameLabel" styleClass="title-label" text="Module Name" />
            <Separator orientation="VERTICAL" />
            <Label fx:id="courseNameLabel" styleClass="subtitle-label" text="Course Name" />
         </HBox>
         <HBox alignment="CENTER_LEFT" spacing="20.0">
            <Label fx:id="progressLabel" styleClass="info-label" text="Progress: 0/10 tasks passed" />
            <ProgressBar fx:id="moduleProgressBar" prefWidth="200.0" progress="0.0" />
         </HBox>
         <Label fx:id="errorLabel" styleClass="error-label" text="Error message" visible="false" />
      </VBox>
   </top>
   <center>
      <HBox>
         <!-- Collapsible Sidebar -->
         <VBox fx:id="sidebar" prefWidth="280.0" spacing="10.0" styleClass="sidebar" managed="false" visible="false">
            <padding>
               <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <Label styleClass="section-header" text="Module Tasks" />
            <ListView fx:id="tasksListView" VBox.vgrow="ALWAYS" />
            <Separator />
            <VBox spacing="8.0" styleClass="attempt-info-box">
               <Label styleClass="section-header" text="Best Attempt:" />
               <Label fx:id="bestAttemptLabel" styleClass="attempt-label" text="No attempts yet" wrapText="true" />
            </VBox>
            <Separator />
            <VBox spacing="5.0">
               <Label styleClass="info-label" text="Complete required tasks to unlock:" wrapText="true" />
               <Button fx:id="takeModuleTestButton" maxWidth="Infinity" onAction="#handleTakeModuleTest" styleClass="test-button" text="Take Module Test" />
            </VBox>
            <Button fx:id="closeButton" maxWidth="Infinity" onAction="#handleClose" text="Close" />
         </VBox>
         
         <!-- Main Content Area -->
         <VBox HBox.hgrow="ALWAYS">
            <SplitPane dividerPositions="0.35" orientation="VERTICAL" VBox.vgrow="ALWAYS">
               <!-- Top Section: Problem Statement (80%) | Sample Test Cases (20%) -->
               <SplitPane dividerPositions="0.8" orientation="HORIZONTAL">
                  <!-- Problem Statement (70%) -->
                  <VBox spacing="10.0">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                     <HBox alignment="CENTER_LEFT" spacing="15.0">
                        <Label fx:id="taskNameLabel" styleClass="task-header" text="Select a task to begin" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label text="Difficulty:" />
                        <Label fx:id="difficultyLabel" styleClass="difficulty-label" text="-" />
                        <Label text="Points:" />
                        <Label fx:id="pointsLabel" text="-" />
                        <Label text="Time:" />
                        <Label fx:id="timeLimitLabel" text="-" />
                        <Label text="Language:" />
                        <Label fx:id="languageLabel" text="-" />
                     </HBox>
                     <Separator />
                     <Label styleClass="section-header" text="Problem Statement:" />
                     <TextArea fx:id="problemStatementArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS" />
                  </VBox>
                  
                  <!-- Sample Test Cases (30%) -->
                  <VBox spacing="10.0">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                     <Label styleClass="section-header" text="Sample Test Cases:" />
                     <TableView fx:id="sampleTestCasesTable" VBox.vgrow="ALWAYS">
                        <columns>
                           <TableColumn fx:id="sampleInputColumn" prefWidth="150.0" text="Input" />
                           <TableColumn fx:id="sampleOutputColumn" prefWidth="150.0" text="Expected Output" />
                        </columns>
                     </TableView>
                  </VBox>
               </SplitPane>
               
               <!-- Bottom Section: Code Editor (80%) | Output (20%) -->
               <SplitPane dividerPositions="0.8" orientation="HORIZONTAL">
                  <!-- Code Editor (80%) -->
                  <VBox spacing="10.0">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                     <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Label styleClass="section-header" text="Your Solution:" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="statusLabel" styleClass="status-label" text="Ready" />
                        <ProgressBar fx:id="executionProgress" prefWidth="100.0" visible="false" />
                        <Button fx:id="runCodeButton" onAction="#handleRunCode" styleClass="run-button" text="▶ Run Code" />
                        <Button fx:id="submitCodeButton" onAction="#handleSubmitCode" styleClass="submit-button" text="✓ Submit Solution" />
                        <Button fx:id="peerHelpButton" onAction="#handlePeerHelp" text="🤝 Peer Help"
                                style="-fx-background-color: #7B1FA2; -fx-text-fill: white; -fx-background-radius: 4;" />
                     </HBox>
                     <TextArea fx:id="codeArea" promptText="Write your code here..." VBox.vgrow="ALWAYS" styleClass="code-editor" />
                  </VBox>
                  
                  <!-- Output (20%) -->
                  <VBox spacing="10.0">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                     <Label styleClass="section-header" text="Output:" />
                     <TextArea fx:id="outputArea" editable="false" VBox.vgrow="ALWAYS" styleClass="output-area" />
                  </VBox>
               </SplitPane>
            </SplitPane>
         </VBox>
      </HBox>
   </center>
</BorderPane>
