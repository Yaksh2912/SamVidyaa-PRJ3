<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.samvidya.controller.TaskManagementController">
   <children>
      <Label fx:id="moduleInfoLabel" text="Tasks for Module">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      
      <Separator />
      
      <TableView fx:id="tasksTable" prefHeight="400.0">
         <columns>
            <TableColumn fx:id="taskNameColumn" prefWidth="250.0" text="Task Name" />
            <TableColumn fx:id="difficultyColumn" prefWidth="100.0" text="Difficulty" />
            <TableColumn fx:id="pointsColumn" prefWidth="80.0" text="Points" />
            <TableColumn fx:id="timeLimitColumn" prefWidth="100.0" text="Time Limit" />
            <TableColumn fx:id="languageColumn" prefWidth="100.0" text="Language" />
         </columns>
      </TableView>
      
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <children>
            <Button fx:id="addTaskButton" mnemonicParsing="false" onAction="#handleAddTask" text="Add Task" styleClass="primary" />
            <Button fx:id="editTaskButton" mnemonicParsing="false" onAction="#handleEditTask" text="Edit Task" />
            <Button fx:id="deleteTaskButton" mnemonicParsing="false" onAction="#handleDeleteTask" text="Delete Task" styleClass="danger" />
         </children>
      </HBox>
      
      <Label fx:id="errorLabel" text="Error message" textFill="RED" visible="false" wrapText="true" />
      
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button fx:id="closeButton" mnemonicParsing="false" onAction="#handleClose" text="Close" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>