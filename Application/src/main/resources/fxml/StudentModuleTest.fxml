<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.samvidya.controller.StudentModuleTestController">
   <top>
      <VBox spacing="10.0" styleClass="header-section">
         <padding>
            <Insets bottom="10.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <HBox alignment="CENTER_LEFT" spacing="20.0">
            <Label fx:id="moduleNameLabel" styleClass="title-label" text="Module Name" />
            <Separator orientation="VERTICAL" />
            <Label fx:id="courseNameLabel" styleClass="subtitle-label" text="Course Name" />
         </HBox>
         <HBox alignment="CENTER_LEFT" spacing="20.0">
            <Label fx:id="testInfoLabel" styleClass="info-label" text="Module Test Information" />
            <Separator orientation="VERTICAL" />
            <Label fx:id="timeRemainingLabel" styleClass="time-label" text="Time Remaining" />
         </HBox>
         <Label fx:id="errorLabel" styleClass="error-label" text="Error message" visible="false" />
      </VBox>
   </top>
   <left>
      <VBox prefWidth="250.0" spacing="10.0" styleClass="sidebar">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <Label styleClass="section-header" text="Questions" />
         <ListView fx:id="questionsListView" prefHeight="400.0" />
         <VBox spacing="5.0">
            <Button fx:id="previousQuestionButton" maxWidth="Infinity" onAction="#handlePreviousQuestion" text="← Previous" />
            <Button fx:id="nextQuestionButton" maxWidth="Infinity" onAction="#handleNextQuestion" text="Next →" />
         </VBox>
         <Separator />
         <Button fx:id="submitTestButton" maxWidth="Infinity" onAction="#handleSubmitTest" styleClass="submit-button" text="Submit Test" />
         <Button fx:id="closeButton" maxWidth="Infinity" onAction="#handleClose" text="Close" />
      </VBox>
   </left>
   <center>
      <SplitPane dividerPositions="0.6" orientation="VERTICAL">
         <VBox spacing="10.0">
            <padding>
               <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <Label fx:id="currentQuestionLabel" styleClass="question-header" text="Question 1 of 5" />
            <VBox spacing="5.0">
               <Label styleClass="section-header" text="Question:" />
               <TextArea fx:id="questionTextArea" editable="false" prefRowCount="2" wrapText="true" />
            </VBox>
            <VBox spacing="5.0">
               <Label styleClass="section-header" text="Problem Statement:" />
               <TextArea fx:id="problemStatementArea" editable="false" prefRowCount="4" wrapText="true" />
            </VBox>
            <VBox spacing="5.0">
               <Label styleClass="section-header" text="Sample Test Cases:" />
               <TableView fx:id="sampleTestCasesTable" prefHeight="120.0">
                  <columns>
                     <TableColumn fx:id="sampleInputColumn" prefWidth="200.0" text="Input" />
                     <TableColumn fx:id="sampleOutputColumn" prefWidth="200.0" text="Expected Output" />
                  </columns>
               </TableView>
            </VBox>
         </VBox>
         <VBox spacing="10.0">
            <padding>
               <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <Label styleClass="section-header" text="Your Solution:" />
               <Button fx:id="runCodeButton" onAction="#handleRunCode" text="Run Code" />
               <ProgressBar fx:id="executionProgress" prefWidth="100.0" visible="false" />
               <Label fx:id="statusLabel" styleClass="status-label" text="Ready" />
            </HBox>
            <TextArea fx:id="codeArea" prefRowCount="10" promptText="Write your code here..." />
            <VBox spacing="5.0">
               <Label styleClass="section-header" text="Output:" />
               <TextArea fx:id="outputArea" editable="false" prefRowCount="8" />
            </VBox>
         </VBox>
      </SplitPane>
   </center>
</BorderPane>