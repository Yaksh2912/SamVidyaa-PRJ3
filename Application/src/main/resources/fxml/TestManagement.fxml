<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.samvidya.controller.TestManagementController">
   <children>
      <Label fx:id="testInfoLabel" text="Test Management">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      
      <Separator />
      
      <TabPane fx:id="testTabPane" tabClosingPolicy="UNAVAILABLE">
         <tabs>
            <Tab fx:id="moduleTestTab" text="Module Tests">
               <content>
                  <VBox spacing="10.0">
                     <children>
                        <Label text="Module Test Questions (Gates for next module)">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font>
                        </Label>
                        
                        <TableView fx:id="moduleTestTable" prefHeight="250.0">
                           <columns>
                              <TableColumn fx:id="moduleQuestionColumn" prefWidth="250.0" text="Question Text" />
                              <TableColumn fx:id="moduleDifficultyColumn" prefWidth="100.0" text="Difficulty" />
                              <TableColumn fx:id="modulePointsColumn" prefWidth="80.0" text="Points" />
                              <TableColumn fx:id="moduleTimeLimitColumn" prefWidth="100.0" text="Time Limit" />
                           </columns>
                        </TableView>
                        
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <Button fx:id="addModuleTestButton" mnemonicParsing="false" onAction="#handleAddModuleTest" text="Add Module Test" styleClass="primary" />
                              <Button fx:id="editModuleTestButton" mnemonicParsing="false" onAction="#handleEditModuleTest" text="Edit" />
                              <Button fx:id="deleteModuleTestButton" mnemonicParsing="false" onAction="#handleDeleteModuleTest" text="Delete" styleClass="danger" />
                           </children>
                        </HBox>
                     </children>
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </VBox>
               </content>
            </Tab>
            <Tab fx:id="courseTestTab" text="Course Tests">
               <content>
                  <VBox spacing="10.0">
                     <children>
                        <Label text="Course Test Questions (Final completion condition)">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font>
                        </Label>
                        
                        <TableView fx:id="courseTestTable" prefHeight="250.0">
                           <columns>
                              <TableColumn fx:id="courseQuestionColumn" prefWidth="250.0" text="Question Text" />
                              <TableColumn fx:id="courseDifficultyColumn" prefWidth="100.0" text="Difficulty" />
                              <TableColumn fx:id="coursePointsColumn" prefWidth="80.0" text="Points" />
                              <TableColumn fx:id="courseTimeLimitColumn" prefWidth="100.0" text="Time Limit" />
                           </columns>
                        </TableView>
                        
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <Button fx:id="addCourseTestButton" mnemonicParsing="false" onAction="#handleAddCourseTest" text="Add Course Test" styleClass="primary" />
                              <Button fx:id="editCourseTestButton" mnemonicParsing="false" onAction="#handleEditCourseTest" text="Edit" />
                              <Button fx:id="deleteCourseTestButton" mnemonicParsing="false" onAction="#handleDeleteCourseTest" text="Delete" styleClass="danger" />
                           </children>
                        </HBox>
                     </children>
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </VBox>
               </content>
            </Tab>
         </tabs>
      </TabPane>
      
      <Label fx:id="errorLabel" text="Error message" textFill="RED" visible="false" wrapText="true" />
      
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button fx:id="closeButton" mnemonicParsing="false" onAction="#handleClose" text="Close" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>