<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" prefHeight="600.0" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.samvidya.controller.CodingQuestionDialogController">
   <content>
      <VBox spacing="15.0">
         <children>
            <Label fx:id="titleLabel" text="Add Test Question">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            
            <GridPane hgap="10.0" vgap="10.0">
               <columnConstraints>
                  <ColumnConstraints hgrow="NEVER" minWidth="140.0" />
                  <ColumnConstraints hgrow="ALWAYS" minWidth="350.0" />
               </columnConstraints>
               
               <Label text="Question Text:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
               <TextField fx:id="questionTextField" promptText="e.g., Implement a function to sort an array" GridPane.columnIndex="1" GridPane.rowIndex="0" />
               
               <Label text="Problem Statement:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
               <TextArea fx:id="problemStatementArea" prefRowCount="4" promptText="Detailed problem statement..." GridPane.columnIndex="1" GridPane.rowIndex="1" />
            </GridPane>
            
            <Separator />
            
            <Label text="Question Configuration">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Label>
            
            <GridPane hgap="15.0" vgap="10.0">
               <columnConstraints>
                  <ColumnConstraints hgrow="NEVER" minWidth="120.0" />
                  <ColumnConstraints hgrow="NEVER" minWidth="150.0" />
                  <ColumnConstraints hgrow="NEVER" minWidth="120.0" />
                  <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" />
               </columnConstraints>
               
               <Label text="Difficulty:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
               <ComboBox fx:id="difficultyComboBox" prefWidth="150.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />
               
               <Label text="Language:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
               <ComboBox fx:id="languageComboBox" prefWidth="150.0" GridPane.columnIndex="3" GridPane.rowIndex="0" />
               
               <Label text="Points:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
               <Spinner fx:id="pointsSpinner" prefWidth="100.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
               
               <Label text="Time Limit (min):" GridPane.columnIndex="2" GridPane.rowIndex="1" />
               <Spinner fx:id="timeLimitSpinner" prefWidth="100.0" GridPane.columnIndex="3" GridPane.rowIndex="1" />
            </GridPane>
            
            <Separator />
            
            <Label text="Test Cases">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Label>
            
            <Label fx:id="testCaseStatsLabel" text="Sample: 0, Validation: 0, Points per validation: 0.00" textFill="#666666" />
            
            <TableView fx:id="testCasesTable" prefHeight="200.0">
               <columns>
                  <TableColumn fx:id="testTypeColumn" prefWidth="80.0" text="Type" />
                  <TableColumn fx:id="inputColumn" prefWidth="150.0" text="Input" />
                  <TableColumn fx:id="outputColumn" prefWidth="150.0" text="Output" />
                  <TableColumn fx:id="testPointsColumn" prefWidth="80.0" text="Points" />
               </columns>
            </TableView>
            
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Button fx:id="addTestCaseButton" mnemonicParsing="false" onAction="#handleAddTestCase" text="Add Test Case" styleClass="primary" />
                  <Button fx:id="editTestCaseButton" mnemonicParsing="false" onAction="#handleEditTestCase" text="Edit" />
                  <Button fx:id="deleteTestCaseButton" mnemonicParsing="false" onAction="#handleDeleteTestCase" text="Delete" styleClass="danger" />
                  <Button fx:id="distributePointsButton" mnemonicParsing="false" onAction="#handleDistributePoints" text="View Points Distribution" styleClass="secondary" />
               </children>
            </HBox>
            
            <Label fx:id="errorLabel" text="Error message" textFill="RED" visible="false" wrapText="true" />
            
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <Button fx:id="cancelButton" mnemonicParsing="false" onAction="#handleCancel" text="Cancel" />
                  <Button fx:id="saveButton" mnemonicParsing="false" onAction="#handleSave" text="Create Question" styleClass="primary" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </content>
</ScrollPane>