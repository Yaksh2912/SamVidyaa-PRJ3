<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.samvidya.controller.AdminUsersManagementController">
    
<VBox spacing="20" style="-fx-background-color: #d8d8d8;">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    
    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label fx:id="titleLabel" text="SamVidya - User Management" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="syncUsersButton" text="☁ Sync Users" onAction="#handleSyncUsers"
                style="-fx-background-radius: 5; -fx-padding: 8 12; -fx-min-width: 110; -fx-background-color: #43A047; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button fx:id="addUserButton" text="Add User" onAction="#handleAddUser" style="-fx-background-radius: 5; -fx-padding: 8 12; -fx-min-width: 100; -fx-background-color: #4caf50; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button fx:id="refreshButton" text="Refresh" onAction="#handleRefresh" styleClass="button-primary"/>
    </HBox>
    
    <!-- Main Content Section -->
    <HBox spacing="20" alignment="TOP_LEFT">
        <!-- Left Side - Registration Codes -->
        <VBox fx:id="registrationCodesSection" spacing="15" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;" prefWidth="500">
            <Label text="Registration Codes" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
            
            <!-- Instructor Registration Code -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Instructor Registration Code:" style="-fx-font-weight: bold; -fx-min-width: 200;"/>
                <TextField fx:id="instructorCodeField" promptText="Instructor Code (6 characters)" style="-fx-background-radius: 5; -fx-padding: 8 12;" HBox.hgrow="ALWAYS" editable="false"/>
                <Button fx:id="editInstructorCodeButton" text="Edit" onAction="#handleEditInstructorCode" style="-fx-background-radius: 5; -fx-padding: 8 12; -fx-min-width: 50; -fx-background-color: #2196F3; -fx-text-fill: white;"/>
                <HBox fx:id="instructorCodeActionButtons" spacing="5" visible="false" managed="false">
                    <Button fx:id="saveInstructorCodeButton" text="✓" onAction="#handleSaveInstructorCode" style="-fx-background-color: #4caf50; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 8 12; -fx-min-width: 40;"/>
                    <Button fx:id="cancelInstructorCodeButton" text="✗" onAction="#handleCancelInstructorCode" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 8 12; -fx-min-width: 40;"/>
                </HBox>
            </HBox>
            
            <!-- Student Registration Code -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Student Registration Code:" style="-fx-font-weight: bold; -fx-min-width: 200;"/>
                <TextField fx:id="studentCodeField" promptText="Student Code (6 characters)" style="-fx-background-radius: 5; -fx-padding: 8 12;" HBox.hgrow="ALWAYS" editable="false"/>
                <Button fx:id="editStudentCodeButton" text="Edit" onAction="#handleEditStudentCode" style="-fx-background-radius: 5; -fx-padding: 8 12; -fx-min-width: 50; -fx-background-color: #2196F3; -fx-text-fill: white;"/>
                <HBox fx:id="studentCodeActionButtons" spacing="5" visible="false" managed="false">
                    <Button fx:id="saveStudentCodeButton" text="✓" onAction="#handleSaveStudentCode" style="-fx-background-color: #4caf50; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 8 12; -fx-min-width: 40;"/>
                    <Button fx:id="cancelStudentCodeButton" text="✗" onAction="#handleCancelStudentCode" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 8 12; -fx-min-width: 40;"/>
                </HBox>
            </HBox>
        </VBox>
        
        <!-- Right Side - Search and Filtering -->
        <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <VBox spacing="2" alignment="TOP_LEFT">
                    <Label text=" " style="-fx-font-weight: bold; -fx-text-fill: transparent; -fx-font-size: 14px;"/>
                    <TextField fx:id="searchField" promptText="Search users..." prefWidth="300" styleClass="search-field"/>
                </VBox>
                <VBox spacing="2">
                    <Label text="Filter by:" style="-fx-font-weight: bold; -fx-text-fill: #333333;"/>
                    <ComboBox fx:id="filterByComboBox" promptText="Filter by" prefWidth="140" styleClass="modern-combo-box"/>
                </VBox>
                <VBox spacing="2">
                    <Label text="Sort by:" style="-fx-font-weight: bold; -fx-text-fill: #333333;"/>
                    <ComboBox fx:id="sortByComboBox" promptText="Sort by" prefWidth="140" styleClass="modern-combo-box"/>
                </VBox>
                <VBox spacing="2">
                    <Label text="Order:" style="-fx-font-weight: bold; -fx-text-fill: #333333;"/>
                    <ComboBox fx:id="sortOrderComboBox" promptText="Order" prefWidth="140" styleClass="modern-combo-box"/>
                </VBox>
            </HBox>
        </VBox>
    </HBox>
    
    <!-- User Type Toggle -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="View:" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
        <ToggleButton fx:id="userTypeToggle" text="Instructors/Admins" onAction="#handleUserTypeToggle" 
                     style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 16; -fx-min-width: 150;" 
                     selected="true"/>
        <Label fx:id="userCountLabel" text="0 users" style="-fx-font-size: 14px; -fx-text-fill: #666666;"/>
    </HBox>
    
    <!-- Users Table -->
    <TableView fx:id="usersTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
        <columns>
            <TableColumn fx:id="serialNoColumn" text="S. No." prefWidth="80"/>
            <TableColumn fx:id="usernameColumn" text="Username" prefWidth="150"/>
            <TableColumn fx:id="passwordColumn" text="Password" prefWidth="200"/>
            <TableColumn fx:id="fullNameColumn" text="Full Name" prefWidth="180"/>
            <TableColumn fx:id="emailColumn" text="Email" prefWidth="250"/>
            <TableColumn fx:id="sectionColumn" text="Section" prefWidth="120"/>
            <TableColumn fx:id="roleColumn" text="Role" prefWidth="120"/>
            <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="280"/>
        </columns>
    </TableView>
    
    <!-- Loading Indicator -->
    <ProgressIndicator fx:id="loadingIndicator" visible="false"/>
    
    <!-- Copyright Footer -->
    <Region VBox.vgrow="ALWAYS"/>
    <VBox alignment="CENTER" spacing="2" style="-fx-padding: 20 0 10 0;">
        <Text style="-fx-font-size: 12px; -fx-fill: #666666; -fx-font-weight: bold;" text="© SamVidya Educational Platform"/>
        <Text style="-fx-font-size: 11px; -fx-fill: #888888;" text="Empowering practical programming education"/>
    </VBox>
</VBox>

</StackPane>