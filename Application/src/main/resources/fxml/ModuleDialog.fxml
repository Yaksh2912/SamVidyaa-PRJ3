<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.samvidya.controller.ModuleDialogController">
   <content>
      <VBox spacing="20.0" style="-fx-background-color: #f8f9fa;">
         <children>
            <!-- Header Section -->
            <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
               <Label fx:id="titleLabel" text="Add New Module" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;">
                  <font>
                     <Font name="System Bold" size="24.0" />
                  </font>
               </Label>
               <Separator style="-fx-background-color: #e9ecef;" />
            </VBox>
            
            <!-- Module Details Section -->
            <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
               <Label text="Module Details" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;">
                  <font>
                     <Font name="System Bold" size="18.0" />
                  </font>
               </Label>
               
               <GridPane hgap="15.0" vgap="15.0">
                  <columnConstraints>
                     <ColumnConstraints hgrow="NEVER" minWidth="140.0" />
                     <ColumnConstraints hgrow="ALWAYS" minWidth="300.0" />
                  </columnConstraints>
                  
                  <Label text="Module Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;" />
                  <TextField fx:id="moduleNameField" promptText="e.g., Variables and Data Types" GridPane.columnIndex="1" GridPane.rowIndex="0" 
                            style="-fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #ddd;" />
                  
                  <Label text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;" />
                  <TextArea fx:id="descriptionArea" prefRowCount="3" promptText="Module description..." GridPane.columnIndex="1" GridPane.rowIndex="1" 
                           style="-fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #ddd;" />
                  
                  <Label text="Module Order:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;" />
                  <Spinner fx:id="moduleOrderSpinner" prefWidth="100.0" GridPane.columnIndex="1" GridPane.rowIndex="2" 
                          style="-fx-background-radius: 5; -fx-border-radius: 5;" />
               </GridPane>
               
               <Separator style="-fx-background-color: #e9ecef;" />
               
               <Label text="Module Configuration" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #34495e;">
                  <font>
                     <Font name="System Bold" size="16.0" />
                  </font>
               </Label>
               
               <HBox spacing="30.0" alignment="CENTER_LEFT">
                  <VBox spacing="5.0">
                     <Label text="Tasks per Module:" style="-fx-font-weight: bold;" />
                     <Spinner fx:id="tasksPerModuleSpinner" prefWidth="100.0" 
                             style="-fx-background-radius: 5; -fx-border-radius: 5;" />
                  </VBox>
                  <VBox spacing="5.0">
                     <Label text="Module Test Questions:" style="-fx-font-weight: bold;" />
                     <Spinner fx:id="moduleTestQuestionsSpinner" prefWidth="100.0" 
                             style="-fx-background-radius: 5; -fx-border-radius: 5;" />
                  </VBox>
                  <CheckBox fx:id="activeCheckBox" text="Module is active" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;" />
               </HBox>
               
               <HBox alignment="CENTER_LEFT" spacing="10.0">
                  <Button fx:id="saveButton" mnemonicParsing="false" onAction="#handleSave" text="Create Module" 
                         style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 10 20;" />
               </HBox>
            </VBox>
            
            <!-- Tasks Section -->
            <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
               <Label text="Module Tasks" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;">
                  <font>
                     <Font name="System Bold" size="18.0" />
                  </font>
               </Label>
               
               <TableView fx:id="tasksTable" prefHeight="200.0" style="-fx-background-radius: 5; -fx-border-radius: 5;">
                  <columns>
                     <TableColumn fx:id="taskNameColumn" prefWidth="200.0" text="Task Name" />
                     <TableColumn fx:id="taskPointsColumn" prefWidth="80.0" text="Points" />
                     <TableColumn fx:id="taskLanguageColumn" prefWidth="90.0" text="Language" />
                     <TableColumn fx:id="taskDifficultyColumn" prefWidth="90.0" text="Difficulty" />
                     <TableColumn fx:id="taskTimeLimitColumn" prefWidth="100.0" text="Time Limit (min)" />
                     <TableColumn fx:id="taskTestCasesColumn" prefWidth="100.0" text="Test Cases" />
                  </columns>
               </TableView>
               
               <HBox alignment="CENTER_LEFT" spacing="10.0">
                  <Button fx:id="addTaskButton" mnemonicParsing="false" onAction="#handleAddTask" text="Add Task" 
                         style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 16;" />
                  <Button fx:id="editTaskButton" mnemonicParsing="false" onAction="#handleEditTask" text="Edit Task" 
                         style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 16;" />
                  <Button fx:id="deleteTaskButton" mnemonicParsing="false" onAction="#handleDeleteTask" text="Delete Task" 
                         style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 16;" />
               </HBox>
            </VBox>
            
            <!-- Tests Section -->
            <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
               <Label text="Module Tests" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;">
                  <font>
                     <Font name="System Bold" size="18.0" />
                  </font>
               </Label>
               
               <TableView fx:id="testsTable" prefHeight="200.0" style="-fx-background-radius: 5; -fx-border-radius: 5;">
                  <columns>
                     <TableColumn fx:id="testQuestionColumn" prefWidth="200.0" text="Question Text" />
                     <TableColumn fx:id="testPointsColumn" prefWidth="80.0" text="Points" />
                     <TableColumn fx:id="testLanguageColumn" prefWidth="90.0" text="Language" />
                     <TableColumn fx:id="testDifficultyColumn" prefWidth="90.0" text="Difficulty" />
                     <TableColumn fx:id="testTimeLimitColumn" prefWidth="100.0" text="Time Limit (min)" />
                     <TableColumn fx:id="testTestCasesColumn" prefWidth="100.0" text="Test Cases" />
                  </columns>
               </TableView>
               
               <HBox alignment="CENTER_LEFT" spacing="10.0">
                  <Button fx:id="addTestButton" mnemonicParsing="false" onAction="#handleAddTest" text="Add Test" 
                         style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 16;" />
                  <Button fx:id="editTestButton" mnemonicParsing="false" onAction="#handleEditTest" text="Edit Test" 
                         style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 16;" />
                  <Button fx:id="deleteTestButton" mnemonicParsing="false" onAction="#handleDeleteTest" text="Delete Test" 
                         style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 16;" />
               </HBox>
            </VBox>
            
            <!-- Error and Close Section -->
            <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
               <Label fx:id="errorLabel" text="Error message" textFill="#e74c3c" visible="false" wrapText="true" 
                     style="-fx-font-weight: bold; -fx-background-color: #fdf2f2; -fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #e74c3c; -fx-border-radius: 5;" />
               
               <HBox alignment="CENTER_RIGHT" spacing="10.0">
                  <Button fx:id="cancelButton" mnemonicParsing="false" onAction="#handleCancel" text="Cancel" 
                         style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 10 20;" />
               </HBox>
            </VBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </content>
</ScrollPane>