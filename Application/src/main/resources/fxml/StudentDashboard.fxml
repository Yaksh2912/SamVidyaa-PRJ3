<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.samvidya.controller.StudentDashboardController">
   <children>
      <HBox alignment="CENTER_LEFT" spacing="20.0">
         <children>
            <VBox spacing="5.0">
               <children>
                  <Label fx:id="welcomeLabel" text="Welcome, Student">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
                  <Label fx:id="enrollmentLabel" text="Enrollment Number: " />
               </children>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <VBox alignment="TOP_RIGHT" spacing="5.0">
               <children>
                  <Label text="Total Points" style="-fx-text-fill: #666666; -fx-font-size: 12px;" />
                  <HBox alignment="CENTER_RIGHT" spacing="5.0">
                     <children>
                        <Label text="🏆" style="-fx-font-size: 20px;" />
                        <Label fx:id="totalPointsLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #ffc107;" />
                        <Label text="pts" style="-fx-font-size: 14px; -fx-text-fill: #666666;" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            <Button fx:id="logoutButton" mnemonicParsing="false" onAction="#handleLogout" text="Logout" />
         </children>
      </HBox>
      
      <Separator />
      
      <!-- Peer help notification bar (hidden by default, shown when a request arrives) -->
      <HBox fx:id="peerHelpNotificationBar" alignment="CENTER_LEFT" spacing="12"
            visible="false" managed="false"
            style="-fx-background-color: #7B1FA2; -fx-padding: 10 16; -fx-background-radius: 6;">
         <Label fx:id="peerHelpNotificationLabel" text=""
                style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" HBox.hgrow="ALWAYS" wrapText="true"/>
         <Button fx:id="acceptPeerHelpButton" text="Accept" onAction="#handleAcceptPeerHelp"
                 style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-padding: 6 14;"/>
         <Button fx:id="rejectPeerHelpButton" text="Reject" onAction="#handleRejectPeerHelp"
                 style="-fx-background-color: #e53935; -fx-text-fill: white; -fx-background-radius: 4; -fx-padding: 6 14;"/>
      </HBox>

      <VBox spacing="15.0">
         <children>
            <Label text="Available Courses">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            
            <TableView fx:id="coursesTable" prefHeight="400.0" styleClass="modern-table">
               <columns>
                  <TableColumn fx:id="courseCodeColumn" prefWidth="100.0" text="Code" />
                  <TableColumn fx:id="courseNameColumn" prefWidth="200.0" text="Course Name" />
                  <TableColumn fx:id="subjectColumn" prefWidth="100.0" text="Subject" />
                  <TableColumn fx:id="instructorColumn" prefWidth="150.0" text="Instructor" />
                  <TableColumn fx:id="progressColumn" prefWidth="120.0" text="Progress" />
                  <TableColumn fx:id="coursePointsColumn" prefWidth="100.0" text="Points" />
                  <TableColumn fx:id="statusColumn" prefWidth="120.0" text="Status" />
                  <TableColumn fx:id="nextActionColumn" prefWidth="150.0" text="Next Action" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            
            <HBox alignment="CENTER_LEFT" spacing="15.0">
               <children>
                  <Button fx:id="startCourseButton" mnemonicParsing="false" onAction="#handleStartCourse" text="Start Course" styleClass="primary" />
                  <Button fx:id="viewProgressButton" mnemonicParsing="false" onAction="#handleViewProgress" text="View Progress" />
               </children>
            </HBox>
         </children>
      </VBox>
      
      <Label fx:id="errorLabel" text="Error message" textFill="RED" visible="false" wrapText="true" />
      
      <Region VBox.vgrow="ALWAYS" />
      
      <HBox alignment="CENTER">
         <children>
            <Label text="SamVidya - Student Learning Platform" textFill="#666666" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>