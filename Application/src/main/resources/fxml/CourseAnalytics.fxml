<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.samvidya.controller.CourseAnalyticsController"
      spacing="0" style="-fx-background-color: #f0f0f0;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15"
          style="-fx-background-color: #1565C0; -fx-padding: 14 20;">
        <Label fx:id="titleLabel" text="Course Analytics"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="syncButton" text="☁ Sync Data" onAction="#handleSyncData"
                style="-fx-background-color: #43A047; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 5; -fx-padding: 6 14;"/>
        <Button text="Close" onAction="#handleClose"
                style="-fx-background-color: #e53935; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 5; -fx-padding: 6 14;"/>
    </HBox>

    <!-- Section filter bar -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: #1976D2; -fx-padding: 8 20;">
        <Label text="Filter by Section:" style="-fx-text-fill: white; -fx-font-size: 13px;"/>
        <ComboBox fx:id="sectionCombo" promptText="All Sections"
                  style="-fx-font-size: 13px;" prefWidth="180"
                  onAction="#handleSectionFilter"/>
        <Button text="Clear Filter" onAction="#handleClearFilter"
                style="-fx-background-color: #90CAF9; -fx-font-size: 12px; -fx-background-radius: 4; -fx-padding: 4 10;"/>
    </HBox>

    <!-- Tab pane -->
    <TabPane fx:id="tabPane" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE"
             style="-fx-tab-min-width: 130px;">

        <!-- ── Analytics Tab ── -->
        <Tab text="Analytics">
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                <VBox spacing="16" style="-fx-padding: 20;">

                    <!-- Averages cards -->
                    <Label text="Course Averages (per enrolled student)"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #333;"/>

                    <GridPane hgap="14" vgap="14">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="33.3"/>
                            <ColumnConstraints percentWidth="33.3"/>
                            <ColumnConstraints percentWidth="33.3"/>
                        </columnConstraints>

                        <!-- Row 0 -->
                        <VBox styleClass="stat-card" GridPane.columnIndex="0" GridPane.rowIndex="0"
                              style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 14; -fx-effect: dropshadow(gaussian,#ccc,4,0,0,2);">
                            <Label text="Avg Tasks Completed" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                            <Label fx:id="avgTasksLabel" text="—"
                                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1565C0;"/>
                        </VBox>
                        <VBox styleClass="stat-card" GridPane.columnIndex="1" GridPane.rowIndex="0"
                              style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 14; -fx-effect: dropshadow(gaussian,#ccc,4,0,0,2);">
                            <Label text="Avg Modules Completed" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                            <Label fx:id="avgModulesLabel" text="—"
                                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
                        </VBox>
                        <VBox styleClass="stat-card" GridPane.columnIndex="2" GridPane.rowIndex="0"
                              style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 14; -fx-effect: dropshadow(gaussian,#ccc,4,0,0,2);">
                            <Label text="Avg Questions Completed" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                            <Label fx:id="avgQuestionsLabel" text="—"
                                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #6A1B9A;"/>
                        </VBox>

                        <!-- Row 1 -->
                        <VBox styleClass="stat-card" GridPane.columnIndex="0" GridPane.rowIndex="1"
                              style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 14; -fx-effect: dropshadow(gaussian,#ccc,4,0,0,2);">
                            <Label text="Avg Points per Task" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                            <Label fx:id="avgPtsTaskLabel" text="—"
                                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #E65100;"/>
                        </VBox>
                        <VBox styleClass="stat-card" GridPane.columnIndex="1" GridPane.rowIndex="1"
                              style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 14; -fx-effect: dropshadow(gaussian,#ccc,4,0,0,2);">
                            <Label text="Avg Points per Module" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                            <Label fx:id="avgPtsModuleLabel" text="—"
                                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #00695C;"/>
                        </VBox>
                        <VBox styleClass="stat-card" GridPane.columnIndex="2" GridPane.rowIndex="1"
                              style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 14; -fx-effect: dropshadow(gaussian,#ccc,4,0,0,2);">
                            <Label text="Avg Points per Question" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                            <Label fx:id="avgPtsQuestionLabel" text="—"
                                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #AD1457;"/>
                        </VBox>

                        <!-- Row 2 -->
                        <VBox styleClass="stat-card" GridPane.columnIndex="0" GridPane.rowIndex="2"
                              style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 14; -fx-effect: dropshadow(gaussian,#ccc,4,0,0,2);">
                            <Label text="Avg Total Points in Course" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                            <Label fx:id="avgPtsCourseLabel" text="—"
                                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1565C0;"/>
                        </VBox>
                        <VBox styleClass="stat-card" GridPane.columnIndex="1" GridPane.rowIndex="2"
                              style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 14; -fx-effect: dropshadow(gaussian,#ccc,4,0,0,2);">
                            <Label text="Avg Attempts per Task" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                            <Label fx:id="avgAttemptsLabel" text="—"
                                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #4527A0;"/>
                        </VBox>
                        <VBox styleClass="stat-card" GridPane.columnIndex="2" GridPane.rowIndex="2"
                              style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 14; -fx-effect: dropshadow(gaussian,#ccc,4,0,0,2);">
                            <Label text="Course Test Pass Rate" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                            <Label fx:id="courseTestPassRateLabel" text="—"
                                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
                        </VBox>
                    </GridPane>

                    <!-- Module funnel table -->
                    <Label text="Module Completion Funnel"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #333; -fx-padding: 8 0 0 0;"/>
                    <TableView fx:id="funnelTable" prefHeight="200">
                        <columns>
                            <TableColumn fx:id="funnelModuleCol" text="Module" prefWidth="300"/>
                            <TableColumn fx:id="funnelStudentsCol" text="Students Reached" prefWidth="160"/>
                        </columns>
                    </TableView>

                    <!-- Task pass rates table -->
                    <Label text="Task Pass Rates"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #333; -fx-padding: 8 0 0 0;"/>
                    <TableView fx:id="taskPassTable" prefHeight="220">
                        <columns>
                            <TableColumn fx:id="taskNameCol" text="Task" prefWidth="340"/>
                            <TableColumn fx:id="taskPassRateCol" text="Pass Rate %" prefWidth="140"/>
                        </columns>
                    </TableView>

                </VBox>
            </ScrollPane>
        </Tab>

        <!-- ── Leaderboard Tab ── -->
        <Tab text="Leaderboards">
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                <VBox spacing="20" style="-fx-padding: 20;">

                    <!-- Tasks Completed -->
                    <Label text="Most Tasks Completed"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1565C0;"/>
                    <TableView fx:id="lbTasksTable" prefHeight="200">
                        <columns>
                            <TableColumn fx:id="lbTasksRankCol"    text="#"       prefWidth="50"/>
                            <TableColumn fx:id="lbTasksNameCol"    text="Student" prefWidth="220"/>
                            <TableColumn fx:id="lbTasksSectionCol" text="Section" prefWidth="120"/>
                            <TableColumn fx:id="lbTasksValCol"     text="Tasks"   prefWidth="80"/>
                        </columns>
                    </TableView>

                    <!-- Perfect Tasks -->
                    <Label text="Most Perfect Tasks (100% score)"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;"/>
                    <TableView fx:id="lbPerfectTasksTable" prefHeight="200">
                        <columns>
                            <TableColumn fx:id="lbPTRankCol"    text="#"            prefWidth="50"/>
                            <TableColumn fx:id="lbPTNameCol"    text="Student"      prefWidth="220"/>
                            <TableColumn fx:id="lbPTSectionCol" text="Section"      prefWidth="120"/>
                            <TableColumn fx:id="lbPTValCol"     text="Perfect Tasks" prefWidth="100"/>
                        </columns>
                    </TableView>

                    <!-- Questions Completed -->
                    <Label text="Most Questions Completed"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #6A1B9A;"/>
                    <TableView fx:id="lbQuestionsTable" prefHeight="200">
                        <columns>
                            <TableColumn fx:id="lbQRankCol"    text="#"         prefWidth="50"/>
                            <TableColumn fx:id="lbQNameCol"    text="Student"   prefWidth="220"/>
                            <TableColumn fx:id="lbQSectionCol" text="Section"   prefWidth="120"/>
                            <TableColumn fx:id="lbQValCol"     text="Questions" prefWidth="90"/>
                        </columns>
                    </TableView>

                    <!-- Perfect Questions -->
                    <Label text="Most Perfect Questions (100% score)"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #AD1457;"/>
                    <TableView fx:id="lbPerfectQTable" prefHeight="200">
                        <columns>
                            <TableColumn fx:id="lbPQRankCol"    text="#"               prefWidth="50"/>
                            <TableColumn fx:id="lbPQNameCol"    text="Student"         prefWidth="220"/>
                            <TableColumn fx:id="lbPQSectionCol" text="Section"         prefWidth="120"/>
                            <TableColumn fx:id="lbPQValCol"     text="Perfect Qs"      prefWidth="90"/>
                        </columns>
                    </TableView>

                    <!-- Most Points -->
                    <Label text="Most Points Earned"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #E65100;"/>
                    <TableView fx:id="lbPointsTable" prefHeight="200">
                        <columns>
                            <TableColumn fx:id="lbPtsRankCol"    text="#"       prefWidth="50"/>
                            <TableColumn fx:id="lbPtsNameCol"    text="Student" prefWidth="220"/>
                            <TableColumn fx:id="lbPtsSectionCol" text="Section" prefWidth="120"/>
                            <TableColumn fx:id="lbPtsValCol"     text="Points"  prefWidth="80"/>
                        </columns>
                    </TableView>

                    <!-- Most Peer Helps Given -->
                    <Label text="Most Students Helped (Peer Help)"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #7B1FA2;"/>
                    <TableView fx:id="lbPeerHelpsTable" prefHeight="200">
                        <columns>
                            <TableColumn fx:id="lbPHRankCol"    text="#"            prefWidth="50"/>
                            <TableColumn fx:id="lbPHNameCol"    text="Student"      prefWidth="220"/>
                            <TableColumn fx:id="lbPHSectionCol" text="Section"      prefWidth="120"/>
                            <TableColumn fx:id="lbPHValCol"     text="Helped"       prefWidth="80"/>
                        </columns>
                    </TableView>

                    <!-- Most Peer Help Points Earned -->
                    <Label text="Most Points Earned via Peer Help"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #00695C;"/>
                    <TableView fx:id="lbPeerHelpPtsTable" prefHeight="200">
                        <columns>
                            <TableColumn fx:id="lbPHPtsRankCol"    text="#"       prefWidth="50"/>
                            <TableColumn fx:id="lbPHPtsNameCol"    text="Student" prefWidth="220"/>
                            <TableColumn fx:id="lbPHPtsSectionCol" text="Section" prefWidth="120"/>
                            <TableColumn fx:id="lbPHPtsValCol"     text="Pts"     prefWidth="80"/>
                        </columns>
                    </TableView>

                </VBox>
            </ScrollPane>
        </Tab>

    </TabPane>

</VBox>
