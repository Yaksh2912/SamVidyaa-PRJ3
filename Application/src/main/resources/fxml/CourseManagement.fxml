<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" prefHeight="800.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.samvidya.controller.CourseManagementController">
   <content>
      <VBox spacing="20.0" style="-fx-background-color: #f8f9fa;">
         <children>
            <!-- Header Section -->
            <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
               <Label fx:id="courseInfoLabel" text="Manage Course" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;">
                  <font>
                     <Font name="System Bold" size="24.0" />
                  </font>
               </Label>
               <Separator style="-fx-background-color: #e9ecef;" />
            </VBox>
            
            <!-- Course Details Section -->
            <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
               <Label text="Course Details" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;">
                  <font>
                     <Font name="System Bold" size="18.0" />
                  </font>
               </Label>
               
               <GridPane hgap="15.0" vgap="15.0">
                  <columnConstraints>
                     <ColumnConstraints hgrow="NEVER" minWidth="140.0" />
                     <ColumnConstraints hgrow="ALWAYS" minWidth="300.0" />
                  </columnConstraints>
                  
                  <Label text="Course Code:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;" />
                  <TextField fx:id="courseCodeField" promptText="e.g., CS101" GridPane.columnIndex="1" GridPane.rowIndex="0" 
                            style="-fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #ddd;" />
                  
                  <Label text="Course Name:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;" />
                  <TextField fx:id="courseNameField" promptText="e.g., Introduction to Python" GridPane.columnIndex="1" GridPane.rowIndex="1" 
                            style="-fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #ddd;" />
                  
                  <Label text="Subject:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;" />
                  <ComboBox fx:id="subjectComboBox" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="2" 
                           style="-fx-background-radius: 5; -fx-border-radius: 5;" />
                  
                  <Label text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold;" />
                  <TextArea fx:id="descriptionArea" prefRowCount="3" promptText="Course description..." GridPane.columnIndex="1" GridPane.rowIndex="3" 
                           style="-fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #ddd;" />
               </GridPane>
               
               <HBox spacing="20.0" alignment="CENTER_LEFT">
                  <Label text="Course Test Questions:" style="-fx-font-weight: bold;" />
                  <Spinner fx:id="courseTestQuestionsSpinner" prefWidth="100.0" 
                          style="-fx-background-radius: 5; -fx-border-radius: 5;" />
                  <CheckBox fx:id="activeCheckBox" text="Course is active" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;" />
               </HBox>
               
               <HBox alignment="CENTER_LEFT" spacing="10.0">
                  <children>
                     <Button fx:id="saveCourseButton" mnemonicParsing="false" onAction="#handleSaveCourse" text="Save Course Changes" 
                            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 10 20;" />
                     <Button fx:id="exportCourseButton" mnemonicParsing="false" onAction="#handleExportCourse" text="Export Course" 
                            style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 10 20;" />
                  </children>
               </HBox>
            </VBox>
            
            <!-- Course Tests Section -->
            <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
               <Label text="Course Tests" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;">
                  <font>
                     <Font name="System Bold" size="18.0" />
                  </font>
               </Label>
               
               <TableView fx:id="courseTestsTable" prefHeight="220.0" style="-fx-background-radius: 5; -fx-border-radius: 5;">
                  <columns>
                     <TableColumn fx:id="testQuestionTextColumn" prefWidth="280.0" text="Question Text" />
                     <TableColumn fx:id="testPointsColumn" prefWidth="80.0" text="Points" />
                     <TableColumn fx:id="testLanguageColumn" prefWidth="90.0" text="Language" />
                     <TableColumn fx:id="testDifficultyColumn" prefWidth="90.0" text="Difficulty" />
                     <TableColumn fx:id="testTimeLimitColumn" prefWidth="110.0" text="Time Limit (min)" />
                     <TableColumn fx:id="testCasesCountColumn" prefWidth="120.0" text="Test Cases" />
                  </columns>
               </TableView>
               
               <HBox alignment="CENTER_LEFT" spacing="10.0">
                  <children>
                     <Button fx:id="addCourseTestButton" mnemonicParsing="false" onAction="#handleAddCourseTest" text="Add Course Test" 
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 16;" />
                     <Button fx:id="editCourseTestButton" mnemonicParsing="false" onAction="#handleEditCourseTest" text="Edit Test" 
                            style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 16;" />
                     <Button fx:id="deleteCourseTestButton" mnemonicParsing="false" onAction="#handleDeleteCourseTest" text="Delete Test" 
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 16;" />
                  </children>
               </HBox>
            </VBox>
            
            <!-- Course Modules Section -->
            <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
               <Label text="Course Modules" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;">
                  <font>
                     <Font name="System Bold" size="18.0" />
                  </font>
               </Label>
               
               <TableView fx:id="modulesTable" prefHeight="250.0" style="-fx-background-radius: 5; -fx-border-radius: 5;">
                  <columns>
                     <TableColumn fx:id="moduleNameColumn" prefWidth="200.0" text="Module Name" />
                     <TableColumn fx:id="moduleOrderColumn" prefWidth="60.0" text="Order" />
                     <TableColumn fx:id="tasksPerModuleColumn" prefWidth="80.0" text="Config Tasks" />
                     <TableColumn fx:id="testQuestionsColumn" prefWidth="90.0" text="Config Tests" />
                     <TableColumn fx:id="totalTasksColumn" prefWidth="80.0" text="Total Tasks" />
                     <TableColumn fx:id="totalTestQuestionsColumn" prefWidth="90.0" text="Total Tests" />
                     <TableColumn fx:id="moduleActionsColumn" prefWidth="80.0" text="Actions" />
                  </columns>
               </TableView>
               
               <HBox alignment="CENTER_LEFT" spacing="10.0">
                  <children>
                     <Button fx:id="addModuleButton" mnemonicParsing="false" onAction="#handleAddModule" text="Add Module" 
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 16;" />
                     <Button fx:id="editModuleButton" mnemonicParsing="false" onAction="#handleEditModule" text="Edit Module" 
                            style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 16;" />
                     <Button fx:id="exportModuleButton" mnemonicParsing="false" onAction="#handleExportModule" text="Export Module" 
                            style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 16;" />
                     <Button fx:id="importModuleButton" mnemonicParsing="false" onAction="#handleImportModule" text="Import Module" 
                            style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 16;" />
                     <Button fx:id="manageTasksButton" mnemonicParsing="false" onAction="#handleManageTasks" text="Manage Tasks" 
                            style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 16;" />
                     <Button fx:id="manageTestsButton" mnemonicParsing="false" onAction="#handleManageTests" text="Manage Tests" 
                            style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 16;" />
                     <Button fx:id="manageStudentsButton" mnemonicParsing="false" onAction="#handleManageStudents" text="Manage Students" 
                            style="-fx-background-color: #16a085; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 16;" />
                     <Button fx:id="deleteModuleButton" mnemonicParsing="false" onAction="#handleDeleteModule" text="Delete Module" 
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 16;" />
                  </children>
               </HBox>
            </VBox>
            
            <!-- All Tasks Section -->
            <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
               <Label text="All Tasks" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;">
                  <font>
                     <Font name="System Bold" size="18.0" />
                  </font>
               </Label>
               
               <TableView fx:id="allTasksTable" prefHeight="300.0" style="-fx-background-radius: 5; -fx-border-radius: 5;">
                  <columns>
                     <TableColumn fx:id="taskModuleColumn" prefWidth="150.0" text="Module" />
                     <TableColumn fx:id="taskNameColumn" prefWidth="200.0" text="Task Name" />
                     <TableColumn fx:id="taskDifficultyColumn" prefWidth="80.0" text="Difficulty" />
                     <TableColumn fx:id="taskPointsColumn" prefWidth="70.0" text="Points" />
                     <TableColumn fx:id="taskLanguageColumn" prefWidth="80.0" text="Language" />
                     <TableColumn fx:id="taskTimeLimitColumn" prefWidth="90.0" text="Time Limit" />
                     <TableColumn fx:id="taskActionsColumn" prefWidth="150.0" text="Actions" />
                  </columns>
               </TableView>
            </VBox>
            
            <!-- All Questions Section -->
            <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
               <Label text="All Questions" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;">
                  <font>
                     <Font name="System Bold" size="18.0" />
                  </font>
               </Label>
               
               <TableView fx:id="allQuestionsTable" prefHeight="300.0" style="-fx-background-radius: 5; -fx-border-radius: 5;">
                  <columns>
                     <TableColumn fx:id="questionModuleColumn" prefWidth="150.0" text="Module" />
                     <TableColumn fx:id="questionTextColumn" prefWidth="250.0" text="Question" />
                     <TableColumn fx:id="questionDifficultyColumn" prefWidth="80.0" text="Difficulty" />
                     <TableColumn fx:id="questionPointsColumn" prefWidth="70.0" text="Points" />
                     <TableColumn fx:id="questionLanguageColumn" prefWidth="80.0" text="Language" />
                     <TableColumn fx:id="questionTimeLimitColumn" prefWidth="90.0" text="Time Limit" />
                     <TableColumn fx:id="questionActionsColumn" prefWidth="150.0" text="Actions" />
                  </columns>
               </TableView>
            </VBox>
            
            <!-- Error and Close Section -->
            <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
               <Label fx:id="errorLabel" text="Error message" textFill="#e74c3c" visible="false" wrapText="true" 
                     style="-fx-font-weight: bold; -fx-background-color: #fdf2f2; -fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #e74c3c; -fx-border-radius: 5;" />
               
               <HBox alignment="CENTER_RIGHT" spacing="10.0">
                  <children>
                     <Button fx:id="closeButton" mnemonicParsing="false" onAction="#handleClose" text="Close" 
                            style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 10 20;" />
                  </children>
               </HBox>
            </VBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </content>
</ScrollPane>